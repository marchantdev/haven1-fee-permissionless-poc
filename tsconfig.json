{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "ignoreDeprecations": "6.0"
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
